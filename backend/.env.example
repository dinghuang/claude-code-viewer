# ============ Claude Code SDK 配置 ============
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5

# Claude Code 工作目录 (Claude Code CLI 在此目录下执行)
WORKING_DIRECTORY=.

# Claude Code CLI 路径 (可选，默认使用 SDK 内置)
# CLAUDE_CODE_CLI_PATH=/usr/local/bin/claude

# Claude Code MCP 服务器配置 (JSON 格式，可选)
# 支持 stdio / sse / http 三种类型
# 示例:
# CLAUDE_CODE_MCP_SERVERS={"web_reader":{"type":"sse","url":"http://localhost:3100/sse"},"my_tool":{"command":"npx","args":["-y","my-mcp-server"]}}
CLAUDE_CODE_MCP_SERVERS=

# ============ CopilotKit LLM 配置 ============
COPILOTKIT_LLM_API_KEY=your_api_key_here
COPILOTKIT_LLM_BASE_URL=https://api.anthropic.com
COPILOTKIT_LLM_MODEL=claude-sonnet-4-5

# ============ 系统提示词 + 用户信息配置 ============
SYSTEM_PROMPT_PATH=./system_prompt.md
USER_INFO_PATH=./user_info.md

# ============ SSL 配置 (可选，用于 HTTPS) ============
# SSL_KEYFILE=./certs/server.key
# SSL_CERTFILE=./certs/server.crt

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
DEBUG=true
